#!/usr/bin/env bash
set -euo pipefail

# wt - worktree + kanban + tmux ワークフロー管理 CLI
# https://github.com/lalalasyun/wt-kanban

PROJECT="${WT_PROJECT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
TMUX_SESSION="${WT_TMUX_SESSION:-dev}"
KANBAN_PORT="${WT_PORT:-3484}"
SERVICE_NAME="kanban"

# ──────────────────────────────────────────────

usage() {
  cat <<'EOF'
wt - worktree + kanban + tmux ワークフロー管理

使い方:
  wt add    <タスク説明> [ブランチ]   タスクを作成 (kanban backlog に追加)
  wt start  <task-id>               タスクを開始 (worktree 作成 + エージェント起動)
  wt ls     [カラム]                 タスク一覧 (backlog|in_progress|review|trash)
  wt rm     <task-id>               タスクを削除 (worktree もクリーンアップ)
  wt up                             kanban サーバーを起動
  wt down                           kanban サーバーを停止
  wt log                            kanban サーバーのログ
  wt status                         全体の状態サマリ

環境変数:
  WT_PROJECT        対象リポジトリのパス (デフォルト: git root)
  WT_TMUX_SESSION   tmux セッション名 (デフォルト: dev)
  WT_PORT           kanban ポート (デフォルト: 3484)

例:
  wt up
  wt add "Issue #45: archive search を実装" main
  wt start 34966
  wt ls
  wt rm 34966
  wt down
EOF
}

# ──────────────────────────────────────────────

require_kanban() {
  if ! command -v kanban &>/dev/null; then
    echo "Error: kanban がインストールされていません"
    echo "  sudo npm install -g kanban"
    exit 1
  fi
}

ensure_server() {
  if curl -sf "http://127.0.0.1:${KANBAN_PORT}/" &>/dev/null; then
    return 0
  fi
  echo "kanban サーバーを起動しています..."
  cmd_up
  # 起動待ち
  for i in $(seq 1 10); do
    sleep 1
    if curl -sf "http://127.0.0.1:${KANBAN_PORT}/" &>/dev/null; then
      return 0
    fi
  done
  echo "Error: kanban サーバーの起動に失敗しました"
  echo "  wt log でログを確認してください"
  exit 1
}

# ──────────────────────────────────────────────

cmd_up() {
  require_kanban
  if curl -sf "http://127.0.0.1:${KANBAN_PORT}/" &>/dev/null; then
    echo "kanban: 既に起動中 (port $KANBAN_PORT)"
    return 0
  fi
  if systemctl --user is-enabled "$SERVICE_NAME" &>/dev/null; then
    systemctl --user start "$SERVICE_NAME"
    echo "kanban: 起動 (systemd)"
  else
    echo "kanban: systemd サービス未登録。フォアグラウンドで起動します"
    echo "  永続化するには: wt install-service"
    exec kanban --no-open --port "$KANBAN_PORT"
  fi
  echo "http://127.0.0.1:${KANBAN_PORT}/"
}

cmd_down() {
  if systemctl --user is-enabled "$SERVICE_NAME" &>/dev/null; then
    systemctl --user stop "$SERVICE_NAME"
    echo "kanban: 停止 (systemd)"
  else
    local pid
    pid=$(lsof -ti :"$KANBAN_PORT" 2>/dev/null || true)
    if [ -n "$pid" ]; then
      kill "$pid"
      echo "kanban: 停止 (pid $pid)"
    else
      echo "kanban: 起動していません"
    fi
  fi
}

cmd_log() {
  if systemctl --user is-enabled "$SERVICE_NAME" &>/dev/null; then
    journalctl --user -u "$SERVICE_NAME" -f
  else
    echo "systemd サービス未登録です"
  fi
}

cmd_install_service() {
  require_kanban
  local service_dir="$HOME/.config/systemd/user"
  local service_file="$service_dir/${SERVICE_NAME}.service"
  mkdir -p "$service_dir"
  cat > "$service_file" <<UNIT
[Unit]
Description=Cline Kanban Dashboard
After=network.target

[Service]
ExecStart=$(command -v kanban) --no-open --port ${KANBAN_PORT}
WorkingDirectory=${PROJECT}
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
UNIT
  systemctl --user daemon-reload
  systemctl --user enable "$SERVICE_NAME"
  systemctl --user start "$SERVICE_NAME"
  echo "kanban: systemd サービスを登録・起動しました"
  echo "  再起動後も自動で起動します"
}

cmd_add() {
  local prompt="${1:?タスク説明を指定: wt add <説明> [ブランチ]}"
  local base="${2:-main}"
  require_kanban
  ensure_server
  kanban task create \
    --prompt "$prompt" \
    --project-path "$PROJECT" \
    --base-ref "$base"
}

cmd_start() {
  local task_id="${1:?task-id を指定: wt start <task-id>}"
  require_kanban
  ensure_server
  kanban task start \
    --task-id "$task_id" \
    --project-path "$PROJECT"
}

cmd_ls() {
  local column="${1:-}"
  require_kanban
  ensure_server
  if [ -n "$column" ]; then
    kanban task list --project-path "$PROJECT" --column "$column"
  else
    kanban task list --project-path "$PROJECT"
  fi
}

cmd_rm() {
  local task_id="${1:?task-id を指定: wt rm <task-id>}"
  require_kanban
  ensure_server
  kanban task trash \
    --task-id "$task_id" \
    --project-path "$PROJECT"
}

cmd_status() {
  echo "=== Project ==="
  echo "  $PROJECT"
  echo ""

  echo "=== Kanban ==="
  if curl -sf "http://127.0.0.1:${KANBAN_PORT}/" &>/dev/null; then
    echo "  running (port $KANBAN_PORT)"
  else
    echo "  stopped"
  fi
  if systemctl --user is-enabled "$SERVICE_NAME" &>/dev/null; then
    echo "  $(systemctl --user is-active "$SERVICE_NAME") (systemd)"
  fi
  echo ""

  echo "=== Git Worktrees ==="
  cd "$PROJECT" && git worktree list
  echo ""

  echo "=== tmux ($TMUX_SESSION) ==="
  if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
    tmux list-windows -t "$TMUX_SESSION" -F '  #{window_index}: #{window_name} #{?window_active,(active),}'
  else
    echo "  (セッションなし)"
  fi
}

# ──────────────────────────────────────────────

case "${1:-}" in
  up)      cmd_up ;;
  down)    cmd_down ;;
  log)     cmd_log ;;
  add)     shift; cmd_add "$@" ;;
  start)   shift; cmd_start "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  rm)      shift; cmd_rm "$@" ;;
  status)  cmd_status ;;
  install-service) cmd_install_service ;;
  -h|--help) usage ;;
  *)       usage ;;
esac
